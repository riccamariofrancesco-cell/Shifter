{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel-static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/api/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "env": {
    "DATABASE_URL": "DATABASE_URL",
    "JWT_SECRET": "JWT_SECRET",
    "NODE_ENV": "production"
  }
}